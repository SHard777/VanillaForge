# ==============================================================================
# LOCAL ENVIRONMENT CONFIGURATION
# WARNING: Do NOT commit this file to Git! This file is gitignored.
# ==============================================================================

# ------------------------------------------------------------------------------
# OPTION 1: Google AI Studio API Authentication (Recommended for rapid prototyping)
# ------------------------------------------------------------------------------
# Get your API key from Google AI Studio: https://aistudio.google.com/
# Uncomment the variables below to use the Google Developer API:
# GEMINI_API_KEY="your_google_ai_studio_api_key_here"
# GOOGLE_GENAI_USE_VERTEXAI=False

# ------------------------------------------------------------------------------
# OPTION 2: Google Cloud Platform / Vertex AI Authentication (For production/enterprise)
# ------------------------------------------------------------------------------
# Set your GCP Project ID and desired location (e.g., us-central1)
# You must also authenticate locally by running the following command in your terminal:
#   gcloud auth application-default login
#
# Uncomment the variables below to use Google Cloud / Vertex AI:
# GOOGLE_CLOUD_PROJECT="your_gcp_project_id_here"
# GOOGLE_CLOUD_LOCATION="us-central1"
# GOOGLE_GENAI_USE_VERTEXAI=True
